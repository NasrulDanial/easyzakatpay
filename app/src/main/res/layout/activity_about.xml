<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F9">

    <!-- TOOLBAR -->

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/aboutToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0B6E4F"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About EasyZakat Pay"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_gravity="center_vertical"/>

    </androidx.appcompat.widget.Toolbar>

    <!-- CONTENT -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EasyZakat Pay is a professional mobile application developed to help users calculate gold zakat accurately and efficiently."
                android:textSize="16sp"
                android:textColor="#333333"
                android:padding="16dp"
                android:background="#FFFFFF"
                android:elevation="3dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developer Details"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#0B6E4F"
                android:layout_marginBottom="15dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Name: NASRUL DANIAL BIN JUHAR"
                android:textSize="16sp"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Student ID: 2025386309"
                android:textSize="16sp"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Programme Code: ICT602"
                android:textSize="16sp"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="© 2026 EasyZakat Pay. All Rights Reserved."
                android:textSize="16sp"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Project Repository"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#0B6E4F"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/txtGithub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="https://github.com/yourusername/easyzakatpay"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="16dp"
                android:background="#FFFFFF"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>