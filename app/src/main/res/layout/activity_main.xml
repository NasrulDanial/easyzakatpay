<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F9"
    tools:context=".MainActivity">

    <!-- TOOLBAR -->

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0B6E4F"
        android:elevation="4dp"
        app:title="EasyZakat Pay"
        app:titleTextColor="#FFFFFF"/>

    <!-- SCROLLABLE CONTENT -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- APP DESCRIPTION -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gold Zakat Calculator"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#0B6E4F"
                android:layout_marginBottom="8dp"/>

            <!-- INSTRUCTION CARD -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter all details below to calculate zakat payment accurately."
                android:textSize="15sp"
                android:textColor="#333333"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:elevation="3dp"
                android:layout_marginBottom="20dp"/>

            <!-- INPUT TITLE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gold Information"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#0B6E4F"
                android:layout_marginBottom="16dp"/>

            <!-- GOLD WEIGHT -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gold Weight (gram)"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#222222"/>

            <EditText
                android:id="@+id/edtWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Example: 100"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:backgroundTint="#0B6E4F"
                android:layout_marginBottom="18dp"/>

            <!-- GOLD PRICE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gold Price per Gram (RM)"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#222222"/>

            <EditText
                android:id="@+id/edtPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Example: 520"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:backgroundTint="#0B6E4F"
                android:layout_marginBottom="20dp"/>

            <!-- GOLD TYPE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gold Type"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#222222"/>

            <RadioGroup
                android:id="@+id/radioGroupType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="25dp">

                <RadioButton
                    android:id="@+id/radioKeep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keep"
                    android:textColor="#000000"/>

                <RadioButton
                    android:id="@+id/radioWear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wear"
                    android:textColor="#000000"
                    android:layout_marginStart="25dp"/>

            </RadioGroup>

            <!-- BUTTONS -->

            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Calculate Zakat"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="#0B6E4F"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Reset"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="#C49A00"
                android:layout_marginBottom="25dp"/>

            <!-- RESULT TITLE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculation Result"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#0B6E4F"
                android:layout_marginBottom="16dp"/>

            <!-- RESULT CARDS -->

            <TextView
                android:id="@+id/txtTotalValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total Gold Value: RM 0.00"
                android:textSize="16sp"
                android:textColor="#222222"
                android:padding="16dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/txtZakatWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Zakat Weight: 0 gram"
                android:textSize="16sp"
                android:textColor="#222222"
                android:padding="16dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/txtZakatPayable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Zakat Payable: RM 0.00"
                android:textSize="16sp"
                android:textColor="#222222"
                android:padding="16dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/txtTotalZakat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total Zakat: RM 0.00"
                android:textStyle="bold"
                android:textColor="#0B6E4F"
                android:textSize="18sp"
                android:padding="18dp"
                android:background="#DFF6E3"
                android:elevation="3dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>